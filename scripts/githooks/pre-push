#!/bin/sh
# Optional pre-push gate. Enable: git config core.hooksPath scripts/githooks
# See scripts/githooks/README.md (WIKI_PRE_PUSH modes).

set -e
repo_root=$(git rev-parse --show-toplevel) || exit 1
cd "$repo_root" || exit 1

mode=${WIKI_PRE_PUSH:-check}
case "$mode" in
	off|0|skip) exit 0 ;;
esac

if ! command -v make >/dev/null 2>&1; then
	echo >&2 "pre-push: make not in PATH (install build tools or use WIKI_PRE_PUSH=off)"
	exit 1
fi

case "$mode" in
	check) exec make wiki-check ;;
	ci) make wiki-ci && exec make wiki-quality-gate ;;
	all) exec make wiki-all ;;
	*)
		echo >&2 "pre-push: unknown WIKI_PRE_PUSH='$mode' (use off, check, ci, all)"
		exit 2
		;;
esac
