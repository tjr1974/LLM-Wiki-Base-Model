# --- Autopilot runtime streams ---
ai/runtime/.autopilot.runtime.lock
ai/runtime/autopilot.ops.ndjson

# Ingest operation log (append-only; embeds absolute paths and subprocess argv)
ai/runtime/ingest.ops.ndjson

# --- Local query / rollup outputs (see README: writeback_artifact, coverage matrix paths) ---
ai/artifacts/
