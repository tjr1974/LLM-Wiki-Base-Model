# Line endings: LF in the repo for predictable CI and diffs on all platforms.
* text=auto

*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.ndjson text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
Makefile text eol=lf
scripts/githooks/pre-push text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Ship fonts as binary so Git does not normalize bytes.
*.ttf binary

# Raster images (site assets or optional root-level maintainer screenshots).
*.png binary
*.jpg binary
*.jpeg binary
